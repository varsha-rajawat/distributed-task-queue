{
  "name": "distributed-task-queue",
  "version": "1.0.0",
  "description": "A distributed task queue with Redis (priority queues, retries) and PostgreSQL (persistence, dead-letter queue) built in Node.js.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node src/db/migrations.js",
    "worker": "node src/worker-entry.js"
  },
  "keywords": ["task-queue", "redis", "postgresql", "distributed-systems", "node.js"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
