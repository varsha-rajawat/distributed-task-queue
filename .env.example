# Application
NODE_ENV=development
PORT=3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=taskqueue
PG_PASSWORD=taskqueue_secret
PG_DATABASE=taskqueue_db

# Queue Settings
DEFAULT_CONCURRENCY=5          # Number of jobs a worker processes in parallel
DEFAULT_MAX_ATTEMPTS=3         # Max retry attempts per job
BACKOFF_BASE_DELAY_MS=1000     # Base delay for exponential backoff (1 second)
JOB_LOCK_TTL_MS=30000          # How long a job is locked while processing (30s)
POLL_INTERVAL_MS=1000          # How often workers poll for new jobs
